{
  "name": "genshin-dictionary-editor",
  "version": "1.0.0",
  "description": "Editor for Genshin Dictionary",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build:payload && next dev",
    "start": "next start",
    "build": "pnpm build:payload && pnpm build:app && pnpm build:sitemap",
    "build:app": "next build",
    "build:payload": "payload generate:importmap && payload generate:types",
    "build:sitemap": "next-sitemap --config next-sitemap.config.cjs",
    "lint": "tsc --noEmit && next lint",
    "fix": "next lint --fix",
    "payload": "payload",
    "clean": "git clean -dX --exclude=\"!.env\" --force",
    "refresh": "pnpm run clean && rm --force ./pnpm-lock.yaml && corepack up && pnpm install",
    "prepare": "pnpm build:payload"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.40.0",
    "@payloadcms/db-sqlite": "3.40.0",
    "@payloadcms/live-preview-react": "3.40.0",
    "@payloadcms/next": "3.40.0",
    "@payloadcms/payload-cloud": "3.40.0",
    "@payloadcms/plugin-form-builder": "3.40.0",
    "@payloadcms/plugin-nested-docs": "3.40.0",
    "@payloadcms/plugin-redirects": "3.40.0",
    "@payloadcms/plugin-search": "3.40.0",
    "@payloadcms/plugin-seo": "3.40.0",
    "@payloadcms/richtext-lexical": "3.40.0",
    "@payloadcms/ui": "3.40.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "^0.378.0",
    "next": "15.3.0",
    "next-sitemap": "^4.2.3",
    "payload": "3.40.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.45.4",
    "sharp": "0.32.6",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@xicri/configs": "latest",
    "@tailwindcss/typography": "^0.5.13",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.5.4",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.2",
    "autoprefixer": "^10.4.19",
    "copyfiles": "^2.4.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.3.0",
    "jiti": "^2.4.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "20.x || >=22.x",
    "pnpm": ">=10.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.14.0-0+sha512.2cd47a0cbf5f1d1de7693a88307a0ede5be94e0d3b34853d800ee775efbea0650cb562b77605ec80bc8d925f5cd27c4dfe8bb04d3a0b76090784c664450d32d6"
}
