{
  "name": "genshin-dictionary",
  "description": "An online Japanese-English dictionary for terms in Genshin Impact",
  "license": "Apache-2.0",
  "author": "Xicri (https://genshin-dictionary.com/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xicri/genshin-dictionary.git"
  },
  "bugs": {
    "url": "https://github.com/xicri/genshin-dictionary/issues"
  },
  "homepage": "https://genshin-dictionary.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm sync && vite dev",
    "build": "pnpm sync && jiti ./scripts/build.ts && vite build",
    "preview": "pnpm build && wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "test": "pnpm sync && vitest run",
    "e2e": "pnpm sync && playwright test --shard=\"${SHARD_INDEX:-1}/${SHARD_TOTAL:-1}\"",
    "e2e:server": "pnpm build && wrangler dev .svelte-kit/cloudflare/_worker.js --show-interactive-dev-session=false --port=5678",
    "e2e:prepare": "playwright install chromium webkit --with-deps",
    "vrt": "pnpm e2e:prepare && concurrently --kill-others --success=first \"npm:e2e:server\" \"npm:vrt:screenshot\" && npm run vrt:reg",
    "vrt:screenshot": "sleep 5 && jiti ./scripts/vrt-screenshot.ts",
    "vrt:reg": "./scripts/vrt-reg.sh",
    "lint": "pnpm sync && svelte-check && eslint",
    "fix": "pnpm sync && eslint --fix",
    "purge-cache": "jiti ./scripts/purge-cache.ts",
    "clean": "git clean -dX --exclude=\"!.env\" --force",
    "refresh": "pnpm clean && rm --force ./pnpm-lock.yaml && corepack up && pnpm install",
    "sync": "wrangler types && svelte-kit sync",
    "prepare": "svelte-kit sync && jiti ./scripts/prepare.ts && pnpm build"
  },
  "dependencies": {
    "@types/luxon": "^3.7.1",
    "dotenv": "^17.2.2",
    "es-toolkit": "^1.45.1",
    "jiti": "^2.5.1",
    "luxon": "^3.7.2",
    "sass": "^1.98.0",
    "super-sitemap": "^1.0.7",
    "tailwind-merge": "^3.4.0",
    "undici": "^8.0.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.15.1",
    "@playwright/test": "^1.59.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "playwright": "^1.59.0",
    "reg-notify-github-plugin": "^0.14.5",
    "reg-publish-s3-plugin": "^0.14.4",
    "reg-simple-keygen-plugin": "^0.14.2",
    "reg-suit": "^0.14.5",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.79.0",
    "xml2js": "^0.6.2"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
