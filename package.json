{
  "name": "genshin-dictionary",
  "description": "An online Japanese-English dictionary for terms in Genshin Impact",
  "license": "Apache-2.0",
  "author": "Xicri (https://genshin-dictionary.com/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xicri/genshin-dictionary.git"
  },
  "bugs": {
    "url": "https://github.com/xicri/genshin-dictionary/issues"
  },
  "homepage": "https://genshin-dictionary.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm sync && vite dev",
    "build": "pnpm sync && jiti ./scripts/build.ts && vite build",
    "preview": "pnpm build && wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "test": "pnpm sync && vitest run",
    "e2e": "pnpm sync && playwright test --shard=\"${SHARD_INDEX}/${SHARD_TOTAL}\"",
    "e2e:server": "wrangler pages dev --local --show-interactive-dev-session=false --port=5678",
    "e2e:prepare": "playwright install chromium webkit --with-deps",
    "vrt": "pnpm e2e:prepare && concurrently --kill-others --success=first \"npm:e2e:server\" \"npm:vrt:screenshot\" && npm run vrt:reg",
    "vrt:screenshot": "sleep 5 && jiti ./scripts/vrt-screenshot.ts",
    "vrt:reg": "./scripts/vrt-reg.sh",
    "lint": "pnpm prepare && svelte-check --tsconfig ./tsconfig.json && eslint",
    "fix": "pnpm sync && eslint --fix",
    "purge-cache": "jiti ./scripts/purge-cache.ts",
    "update-nuxt": "nuxi upgrade --force",
    "clean": "git clean -dX --exclude=\"!.env\" --force",
    "refresh": "pnpm clean && rm --force ./pnpm-lock.yaml && corepack up && pnpm install",
    "sync": "wrangler types && svelte-kit sync",
    "prepare": "node ./scripts/postinstall.mjs && pnpm sync"
  },
  "dependencies": {
    "@escapace/accept-language-parser": "^1.6.7",
    "@nuxt/devtools": "^2.6.3",
    "@nuxt/eslint": "1.9.0",
    "@nuxtjs/i18n": "^9.4.0",
    "@nuxtjs/robots": "^5.5.1",
    "@nuxtjs/sitemap": "^7.2.2",
    "@pinia/nuxt": "0.11.2",
    "@types/lodash-es": "^4.17.9",
    "@types/luxon": "^3.7.1",
    "dotenv": "^17.2.2",
    "jiti": "^2.5.1",
    "klona": "^2.0.4",
    "lodash-es": "^4.17.21",
    "luxon": "^3.7.2",
    "nuxt": "^3.17.1",
    "pinia": "^3.0.1",
    "sass": "^1.92.1",
    "undici": "^7.15.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^9.39.2",
    "@playwright/mcp": "latest",
    "@playwright/test": "^1.55.0",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^24.3.1",
    "@xicri/configs": "^2025.6.15",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "eslint-plugin-jsonc": "^2.21.0",
    "eslint-plugin-svelte": "^3.13.1",
    "globals": "^16.5.0",
    "playwright": "^1.55.0",
    "reg-notify-github-plugin": "^0.14.5",
    "reg-publish-s3-plugin": "^0.14.4",
    "reg-simple-keygen-plugin": "^0.14.2",
    "reg-suit": "^0.14.5",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.6",
    "vitest": "^3.1.1",
    "vue-tsc": "^3.0.6",
    "wrangler": "^4.56.0",
    "xml2js": "^0.6.2"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
